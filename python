@tool
def execute_incident_analysis_pipeline(incident_details: str) -> str:
    """
    Invokes the internal multi-agent graph pipeline to route incident logs
    sequentially through remote AWS cloud nodes and return a structured summary.
    """

    logger.info(
        "Received incident details for processing. Invoking multi-agent analysis pipeline..."
    )

    current_span = trace.get_current_span()
    span_context = current_span.get_span_context()
    trace_id = format(span_context.trace_id, "032x")

    logger.info("Processing request. trace_id=%s", trace_id)

    # Build and execute graph
    compiled_incident_graph = build_incident_graph()
    result = compiled_incident_graph(incident_details)

    analysis_text = (
        result.results[ANALYSIS_NODE]
        .result
        .message["content"][0]["text"]
        )

    logger.info(
        "[ANALYZER_OUTPUT] %s",
        analysis_text
    )

    analysis_hash = hashlib.sha256(
        analysis_text.encode("utf-8")
        ).hexdigest()

    logger.debug(
        "[ORCH_ANALYSIS_HASH] %s",
        analysis_hash,
        )

    try:
        # Extract ONLY the summarizer business response
        summary_text = (
            result.results[SUMMARY_NODE]
            .result
            .message["content"][0]["text"]
        )

        logger.info(
                "[FINAL_ANALYZER_RESPONSE] %s",
                result.message["content"][0]["text"]
            )

        summary_hash = hashlib.sha256(
            summary_text.encode("utf-8")
            ).hexdigest()

        logger.info(
            "[ORCHESTRATOR_TOOL_OUTPUT] hash=%s len=%d",
            summary_hash,
            len(summary_text)
        )

        logger.info(
            "Pipeline summary generated. Characters=%s",
            len(summary_text),
        )

        return summary_text

    except Exception as e:
        logger.exception(
            "Failed to extract summary from graph result: %s",
            str(e),
        )

        fallback_text = str(result)

        logger.warning(
            "Falling back to raw graph output. Length=%s",
            len(fallback_text),
        )

        return fallback_text

