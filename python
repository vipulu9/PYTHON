def get_ssm_parameter(param_path: str, fallback_env: str) -> str:
    """Fetches a configuration value from AWS SSM Parameter Store with an env fallback."""
    try:
        response = ssm_client.get_parameter(Name=param_path, WithDecryption=False)
        return response['Parameter']['Value']
    except Exception as e:
        logger.error(f"SSM path {param_path} not found or inaccessible ({e}). Falling back to environment variable.")
        return os.getenv(fallback_env, "")

