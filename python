    incident_count: int = Field(
        description="Total number of incidents"
    )

    affected_systems: str = Field(
        description="Alphabetically sorted affected systems"
    )

    categories: str = Field(
        description="Alphabetically sorted categories"
    )

    priorities: str = Field(
        description="Sorted priorities"
    )

    states: str = Field(
        description="Sorted states"
    )

    short_description: str = Field(
        description="Short description copied from first incident"
    )

    knowledge_base_record_count: int = Field(
        description="Number of KB records"
    )

    summary_text: str = Field(
        description="Final deterministic summary"
    )

# ========================================================
# LOGGING METRICS (Strictly Per-Request)
# ========================================================
def log_metrics_on_complete(event: AfterInvocationEvent) -> None:
    """Triggered automatically by Strands strictly for the current HTTP request."""
    
    if not event.result or not event.result.metrics:
        return

    # Extract metrics ONLY for the single, latest request invocation
    if event.result.metrics.agent_invocations:
        latest_invocation = event.result.metrics.agent_invocations[-1]
        metrics = latest_invocation.usage
        cycle_count = len(latest_invocation.cycles)
    else:
        metrics = event.result.metrics.accumulated_usage
        cycle_count = 1

    input_t = metrics.get('inputTokens', 0)
    output_t = metrics.get('outputTokens', 0)
    cache_w = metrics.get('cacheWriteInputTokens', 0)
    cache_r = metrics.get('cacheReadInputTokens', 0)
    total_tokens = metrics.get('totalTokens', 0)

    # Calculate actual billed tokens
    billed_tokens = (input_t + output_t) - cache_r

    dashboard = (
        f"\n"
        f"┌──────────────────────────────────────────────────┐\n"
        f"│ 📊 ANALYZER SINGLE-REQUEST METRICS               │\n"
        f"├──────────────────────────────────────────────────┤\n"
        f"│ 🔄 Agent Cycles    : {cycle_count}\n"
        f"│ 📥 Standard Input  : {input_t} tokens\n"
        f"│ 📤 Output Generated: {output_t} tokens\n"
        f"│ 💾 Cache Written   : {cache_w} tokens\n"
        f"│ ⚡ Cache Read      : {cache_r} tokens (Discounted!)\n"
        f"├──────────────────────────────────────────────────┤\n"
        f"│ 📈 Total Processed : {total_tokens} tokens\n"
        f"└──────────────────────────────────────────────────┘\n"
    )
    
    logger.info(dashboard)
    
def main():
    # Reads environment variable dynamically. Evaluates to True if set to 'local' (case-insensitive)
    is_local = os.getenv("ENV", "prod").lower() == "local"
    
    summarizer_agent = Agent(
        name="Summarizer Agent",    
        description="Provides an immediate specialist summary on incident data.", 
        model=load_model(),
        system_prompt=SYSTEM_PROMPT,
        tools=tools,
        structured_output_model=IncidentSummary,
    )

    summarizer_agent.add_hook(log_metrics_on_complete, AfterInvocationEvent)

    if is_local:
        logger.info("Running Summarizer Agent in LOCAL mode on port 9003...")
        a2a_server = A2AServer(
            agent=summarizer_agent, 
            port=9003
        )
        a2a_server.serve()
    else:
        logger.info("Running Summarizer Agent in AWS PRODUCTION environment via Bedrock AgentCore Runtime...")
        executor = StrandsA2AExecutor(agent=summarizer_agent)
        serve_a2a(executor)

if __name__ == "__main__":
    main()



