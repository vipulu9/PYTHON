import boto3
import json
from botocore.exceptions import ClientError

from strands.tools import tool
import logging
logging.basicConfig(level=logging.INFO)
logger = logging.getLogger(__name__)

# Initialize the Bedrock AgentCore client
client = boto3.client('bedrock-agentcore', region_name='ap-south-1')
runtime_arn = 'arn:aws:bedrock-agentcore:us-east-1:224198986708:runtime/serviceNowMcpCDK_snowMCP-3vNsk72vu4/runtime-endpoint/DEFAULT'


def call_mcp(method, params=None):
    """
    Call an MCP method on the agent runtime.
    
    Args:
        method: The MCP method to call (e.g., 'tools/list', 'tools/call')
        params: Optional parameters for the method
    
    Returns:
        The result from the MCP response
    """
    logger.info(f"MCP METHOD CALLED: {method}")
    if params is None:
        params = {}

    payload = json.dumps({
        "jsonrpc": "2.0",
        "id": 1,
        "method": method,
        "params": params
    }).encode()

    try:
        response = client.invoke_agent_runtime(
            agentRuntimeArn=runtime_arn,
            payload=payload,
            qualifier='DEFAULT',
            contentType='application/json',
            accept='application/json, text/event-stream'
        )

        raw = response['response'].read().decode()
        import re

        match = re.search(r'\{.*\}', raw, re.DOTALL)

        if not match:
           raise Exception(f"No JSON found in response:\n{raw}")

        json_data = json.loads(match.group(0))
        
        print("\n===== PARSED JSON =====")
        print(json.dumps(json_data, indent=2))
        print("=======================\n")
        
        # ✅ handle all cases
        if "result" in json_data:
            return json_data["result"]
        
        elif "error" in json_data:
            raise Exception(f"MCP Error: {json_data['error']}")
        
        else:
            raise Exception(f"Unexpected MCP response format: {json_data}")
    


        return json_data['result']

    except ClientError as e:
        print(f"\n{'=' * 60}")
        print("Error Response:")
        print(json.dumps(e.response, indent=2, default=str))
        print(f"{'=' * 60}\n")
        raise


from strands.tools import tool
import json

def build_tools_from_mcp():
    tools_response = call_mcp("tools/list")
    tool_defs = tools_response["tools"]

    strands_tools = []

    for t in tool_defs:
        name = t["name"]

        def make_tool(tool_name):
            @tool(name=tool_name)
            def dynamic_tool(**kwargs):
                logger.info(f"TOOL EXECUTED: {tool_name}")
                # ✅ FIX: unwrap kwargs properly
                if "kwargs" in kwargs:
                    try:
                        parsed = kwargs["kwargs"]
                        if isinstance(parsed, str):
                            parsed = json.loads(parsed)
                        return call_mcp("tools/call", {
                            "name": tool_name,
                            "arguments": parsed
                        })
                    except Exception:
                        pass

                return call_mcp("tools/call", {
                    "name": tool_name,
                    "arguments": kwargs
                })

            return dynamic_tool

        strands_tools.append(make_tool(name))

    return strands_tools
