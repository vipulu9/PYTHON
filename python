def _resolve_endpoints_with_retry(
    max_retries: int = REGISTRY_MAX_RETRIES,
    retry_delay: float = REGISTRY_RETRY_DELAY,
) -> tuple[str, str]:
    """Resolve both agent endpoints from the registry, retrying on transient failures.

    Raises:
        RuntimeError: If all retry attempts are exhausted.
    """
    last_error: Exception | None = None
    for attempt in range(1, max_retries + 1):
        try:
            analyzer_ep = resolve_agent_endpoint(ANALYZER_SEARCH_QUERY, REGISTRY_ID, AWS_REGION)
            summarizer_ep = resolve_agent_endpoint(SUMMARIZER_SEARCH_QUERY, REGISTRY_ID, AWS_REGION)
            logger.info("Resolved agent endpoints from registry")
            return analyzer_ep, summarizer_ep
        except Exception as exc:
            last_error = exc
            if attempt < max_retries:
                logger.warning(
                    "Registry lookup failed (attempt %d/%d): %s. Retrying in %.1fs...",
                    attempt,
                    max_retries,
                    exc,
                    retry_delay,
                )
                time.sleep(retry_delay)
            else:
                logger.error(
                    "Registry lookup failed after %d attempts: %s",
                    max_retries,
                    exc,
                )
    raise RuntimeError(
        f"Failed to resolve agent endpoints from registry after {max_retries} attempts."
    ) from last_error


