@tool
def knowledge_base_search(query: str) -> str:
    """Search the Bedrock knowledge base and return structured KB records."""

    logger.info(
        "Executing knowledge_base_search tool. Query: '%s'",
        query
    )

    kb_id = os.getenv("KNOWLEDGE_BASE_ID", "")
    region = os.getenv("AWS_REGION", "us-east-1")

    if not kb_id:
        logger.error("KNOWLEDGE_BASE_ID is missing")
        return json.dumps(
            {
                "record_count": 0,
                "records": [],
                "error": "KNOWLEDGE_BASE_ID not configured"
            }
        )

    tool_input = {
        "toolUseId": "kb-search",
        "input": {
            "text": query,
            "knowledgeBaseId": kb_id,
            "region": region,
            "numberOfResults": 5,
            "score": 0.35,
        },
    }

    try:
        response = _kb_retrieve_fn(tool_input)

        #logger.info("[KB_RAW_RESPONSE] %s", response)

        status = response.get("status", "error")
        content = response.get("content", [])

        logger.info(
            "[KB_CONTENT_COUNT] %s",
            len(content)
        )

        if status != "success" or not content:
            return json.dumps(
                {
                    "record_count": 0,
                    "records": []
                }
            )

        kb_text = content[0].get("text", "")

        # Extract KB incidents
        incident_ids = re.findall(
            r"Incident ID:\s*(INC\d+)",
            kb_text
        )

        summaries = re.findall(
            r"Summary:\s*(.*?)(?=\n\s*Description:)",
            kb_text,
            flags=re.DOTALL,
        )

        resolutions = re.findall(
            r"Resolution:\s*(.*?)(?=\n\s*Score:|\Z)",
            kb_text,
            flags=re.DOTALL,
        )

        records = []

        for idx, incident_id in enumerate(incident_ids):
            records.append(
                {
                    "incident_id": incident_id,
                    "summary": (
                        summaries[idx].strip()
                        if idx < len(summaries)
                        else ""
                    ),
                    "resolution": (
                        resolutions[idx].strip()
                        if idx < len(resolutions)
                        else ""
                    ),
                }
            )

        structured_response = {
            "record_count": len(records),
            "records": records,
        }

        #logger.info("[KB_STRUCTURED_RESPONSE] %s", structured_response)

        return json.dumps(structured_response)

    except Exception as e:
        logger.exception(
            "Error in knowledge_base_search"
        )

        return json.dumps(
            {
                "record_count": 0,
                "records": [],
                "error": str(e),
            }
        )

# ========================================================
# LOGGING METRICS
# ========================================================

def start_metrics_logger(agent, agent_name: str):

    def _worker():

        last_logged_invocation_id = None

        while True:

            try:

                latest = agent.event_loop_metrics.latest_agent_invocation

                if latest is None:
                    time.sleep(2)
                    continue

                if not latest.cycles:
                    time.sleep(2)
                    continue

                usage = latest.usage

                total_tokens = usage.get(
                    "totalTokens",
                    0
                )

                # Skip incomplete invocations
                if total_tokens == 0:
                    time.sleep(2)
                    continue

                invocation_id = (
                    latest.cycles[0].event_loop_cycle_id
                )

                # Skip if already logged
                if invocation_id == last_logged_invocation_id:
                    time.sleep(2)
                    continue

                logger.info(
                    "[%s REQUEST_METRICS] "
                    "cycles=%s "
                    "input=%s "
                    "output=%s "
                    "total=%s "
                    "cache_read=%s "
                    "cache_write=%s",
                    agent_name,
                    len(latest.cycles),
                    usage.get("inputTokens", 0),
                    usage.get("outputTokens", 0),
                    usage.get("totalTokens", 0),
                    usage.get("cacheReadInputTokens", 0),
                    usage.get("cacheWriteInputTokens", 0),
                )

                last_logged_invocation_id = invocation_id

            except Exception:
                logger.exception(
                    "[%s] Failed to collect metrics",
                    agent_name,
                )

            time.sleep(2)

    threading.Thread(
        target=_worker,
        daemon=True,
    ).start()

# ========================================================
#  RUNTIME AND ROUTING UTILITY
# ========================================================
def main():
    logger.info("Starting up AnalyzerAgent system bootstrap lifecycle...")
    
    is_local = os.getenv("ENV", "prod").lower() == "local"
    logger.info("Target execution mode evaluated: [ENV=%s] (is_local=%s)", os.getenv("ENV", "prod"), is_local)
    
    logger.info("Initializing Agent and tools within active OpenTelemetry context framework...")

    try:
        logger.info("Querying MCP Client tool discovery endpoint...")
        tools = build_tools_from_mcp()
        logger.info("MCP discovery complete. Discovered and parsed %d dynamic tools.", len(tools))
        
        logger.info("Loading language intelligence model configuration...")
        llm_model = load_model()
        logger.info("LLM engine loaded successfully: %s", getattr(llm_model, "model_id", "Default Model Instance"))

        logger.info("Assembling Strands Agent runtime configuration framework...")
        analyzer_agent = Agent(
            name="Analyzer Agent",    
            description="Provides insight on incident data.",  
            model=llm_model,
            system_prompt=SYSTEM_PROMPT,
            tools=[*tools, knowledge_base_search],
            structured_output_model=IncidentAnalysis,
        )
        logger.info("Strands Agent assembly verified successfully.")

        
        start_metrics_logger(
            analyzer_agent,
            "ANALYZER"
        )

    except Exception as bootstrap_err:
        logger.critical("Fatal crash experienced during target component assembly pipeline initialization.", exc_info=True)
        raise bootstrap_err

    if is_local:
        logger.info("Configuring A2AServer routing interface loop on target port: 9002")
        a2a_server = A2AServer(
            agent=analyzer_agent, 
            port=9002
        )
        logger.info("Handing off runtime thread execution control to local HTTP polling loop...")
        a2a_server.serve()
    else:
        logger.info("Building production StrandsA2AExecutor. Running in AWS Bedrock AgentCore runtime environment...")
        executor = StrandsA2AExecutor(agent=analyzer_agent)
        
        logger.info("Running in AWS PRODUCTION environment via Bedrock AgentCore Runtime...")
        serve_a2a(executor)

if __name__ == "__main__":
    main()
