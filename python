from strands.hooks import AfterInvocationEvent

# ========================================================
# LOGGING METRICS (The Official Strands Hook Way)
# ========================================================
def log_metrics_on_complete(event: AfterInvocationEvent) -> None:
    """Triggered automatically by Strands exactly when the agent finishes."""
    
    # Ensure we actually have a result to parse
    if not event.result or not event.result.metrics:
        return
        
    # Get the official accumulated metrics for the entire request
    metrics = event.result.metrics.accumulated_usage
    
    input_t = metrics.get('inputTokens', 0)
    output_t = metrics.get('outputTokens', 0)
    cache_w = metrics.get('cacheWriteInputTokens', 0)
    cache_r = metrics.get('cacheReadInputTokens', 0)
    total_tokens = metrics.get('totalTokens', 0)
    
    # Calculate actual billed tokens
    billed_tokens = (input_t + output_t) - cache_r

    # Count how many cycles (Tool calls + reasoning) happened
    cycle_count = len(event.result.metrics.agent_invocations[0].cycles) if event.result.metrics.agent_invocations else 1

    dashboard = (
        f"\n"
        f"┌──────────────────────────────────────────────────┐\n"
        f"│ 📊 ANALYZER REQUEST METRICS SUMMARY \n"
        f"├──────────────────────────────────────────────────┤\n"
        f"│ 🔄 Agent Cycles    : {cycle_count}\n"
        f"│ 📥 Standard Input  : {input_t} tokens\n"
        f"│ 📤 Output Generated: {output_t} tokens\n"
        f"│ 💾 Cache Written   : {cache_w} tokens\n"
        f"│ ⚡ Cache Read      : {cache_r} tokens (Discounted!)\n"
        f"├──────────────────────────────────────────────────┤\n"
        f"│ 📈 Total Processed : {total_tokens} tokens\n"
        f"└──────────────────────────────────────────────────┘\n"
    )
    
    logger.info(dashboard




