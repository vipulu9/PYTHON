import os
import logging
from pydantic import BaseModel, Field
from dotenv import load_dotenv

from mcp_client.client import build_tools_from_mcp
from strands import Agent, tool
from strands.multiagent.a2a.executor import StrandsA2AExecutor
from strands.multiagent.a2a import A2AServer
from bedrock_agentcore.runtime import serve_a2a
from model.load import load_model
from strands_tools.retrieve import retrieve as _kb_retrieve_fn

# Load variables from local .env file
load_dotenv()

logging.basicConfig(level=logging.INFO)
logger = logging.getLogger(__name__)


SYSTEM_PROMPT = """
You are a ServiceNow incident search assistant.

The user provides a natural-language incident description.

Your task is to:
1. FIRST search for existing incidents
2. THEN optionally enrich results using the knowledge base

---

### Allowed Actions

- You MUST first use the incident search/query tool
- AFTER retrieving incidents, you MAY use the knowledge base search tool to get additional context

---

### STRICTLY FORBIDDEN

- DO NOT create incidents
- DO NOT update incidents
- DO NOT call any tool other than:
  - incident search tool (PRIMARY)
  - knowledge base search tool (SECONDARY)
- NEVER use create_incident under any circumstance

---

### Query Rules (Incident Search - FIRST)

1. Use the user input directly

2. Construct a single query using:
   short_descriptionLIKE<user_description>

3. DO NOT:
   - Split into keywords
   - Use multiple LIKE conditions
   - Use OR (^OR)
   - Modify the user input

---

### Knowledge Base Usage (SECOND STEP)

- After retrieving incidents:
  - Extract key terms (e.g., issue type, keywords, error)
  - Use those terms to call the knowledge base search tool

- Use KB ONLY to supplement / add context
- Do NOT replace incident search with KB search

---

### Retrieval Rules

- Incident search result = PRIMARY output
- KB search result = OPTIONAL enrichment

You MAY:
- Append KB insights below incident results

You MUST NOT:
- Modify original incident data
- Filter results
- Rank results
- Remove fields
- Change structure

---

### Output Format

1. Return incident search results EXACTLY as returned
2. OPTIONAL: append KB results under a section like:

--- Knowledge Base Insights ---
<kb_response>

---

### Behavior Guarantee

You are a READ-ONLY agent.
You NEVER perform write actions on ServiceNow.

Execution order is STRICT:
1 → Incident Search  
2 → Knowledge Base (optional)

If unsure → always perform incident search first.
"""


@tool
def knowledge_base_search(query: str) -> str:
    """Search the Bedrock knowledge base for incidents or information. Use this for any knowledge base lookups.

    Args:
        query: The incident ID or search text to find in the knowledge base (e.g. INC000036152332, fibercut)

    Returns:
        Relevant content from the knowledge base matching the query
    """
    kb_id = os.getenv("KNOWLEDGE_BASE_ID")
    region = os.getenv("AWS_REGION", "us-east-1")

    if not kb_id:
        return "Error: KNOWLEDGE_BASE_ID not configured"

    tool_input = {
        'toolUseId': 'kb-search',
        'input': {
            'text': query,
            'knowledgeBaseId': kb_id,
            'region': region,
            'numberOfResults': 5,
            'score': 0.35
        }
    }

    try:
        response = _kb_retrieve_fn(tool_input)
        status = response.get('status', 'error')
        content = response.get('content', [])

        if status != 'success' or not content:
            return f"No results found for: {query}"

        return content[0].get('text', f"No results found for: {query}")

    except Exception as e:
        return f"Search error: {str(e)}"



# ========================================================
#  RUNTIME AND ROUTING UTILITY
# ========================================================
def main():
    # Looks for LOCAL_TESTING=true in your .env file
    is_local = os.getenv("ENV", "prod").lower() == "local"
    
    tools = build_tools_from_mcp()
    print(tools)
    analyzer_agent = Agent(
        name="Analyzer Agent",    
        description="Provides insight on incident data.",  
        model=load_model(),
        system_prompt=SYSTEM_PROMPT,
        tools=[tools, knowledge_base_search],
    )


    if is_local:
        logger.info("Running in LOCAL mode via A2AServer on port 9002...")
        # Local server constructor accepts exactly 'agent_factory'
        a2a_server = A2AServer(
            agent=analyzer_agent, 
            port=9002
        )
        a2a_server.serve()
    else:
        logger.info("Running in AWS PRODUCTION environment via Bedrock AgentCore Runtime...")
        # Production StrandsA2AExecutor wrapper class matches the parameter name 'agent_factory'
        executor = StrandsA2AExecutor(agent=analyzer_agent)
        serve_a2a(executor)

if __name__ == "__main__":
    main()


