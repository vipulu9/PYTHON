class SigV4HTTPXAuth(httpx.Auth):
    """HTTPX Auth class that signs requests with AWS SigV4."""

    def __init__(self, credentials, service: str, region: str):
        self.credentials = credentials
        self.service = service
        self.region = region
        self.signer = SigV4Auth(credentials, service, region)

    def auth_flow(self, request: httpx.Request):
        """Signs the request with SigV4 and adds the signature to the request headers."""
        headers = dict(request.headers)
        headers.pop("connection", None)  # Remove connection header for signature

        aws_request = AWSRequest(
            method=request.method,
            url=str(request.url),
            data=request.content,
            headers=headers,
        )

        self.signer.add_auth(aws_request)
        request.headers.update(dict(aws_request.headers))

        yield request


def build_incident_graph():
    """Create a fresh graph per invocation to avoid cross-event-loop client reuse."""
    graph = GraphBuilder()

    if not use_arn:
        analyzer_remote_agent = A2AAgent(endpoint="http://localhost:9002", name="analyzer_agent")
        summarizer_remote_agent = A2AAgent(endpoint="http://localhost:9003", name="summarizer_agent")
    else:
        region = aws_session.region_name
        credentials = aws_session.get_credentials()
        sigv4_auth = SigV4HTTPXAuth(credentials, "bedrock-agentcore", region)

        analyzer_httpx_client = httpx.AsyncClient(
            timeout=DEFAULT_TIMEOUT,
            auth=sigv4_auth,
        )
        summarizer_httpx_client = httpx.AsyncClient(
            timeout=DEFAULT_TIMEOUT,
            auth=sigv4_auth,
        )

        analyzer_remote_agent = A2AAgent(
            endpoint=analyzer_endpoint,
            name="analyzer_agent",
            client_config=ClientConfig(httpx_client=analyzer_httpx_client),
        )
        summarizer_remote_agent = A2AAgent(
            endpoint=summarizer_endpoint,
            name="summarizer_agent",
            client_config=ClientConfig(httpx_client=summarizer_httpx_client),
        )

    graph.add_node(analyzer_remote_agent, "analysis_step")
    graph.add_node(summarizer_remote_agent, "summary_step")
    graph.add_edge("analysis_step", "summary_step")
    graph.set_entry_point("analysis_step")
    return graph.build()


@tool
def execute_incident_analysis_pipeline(incident_details: str) -> str:
    """
    Invokes the internal multi-agent graph pipeline to route incident logs 
    sequentially through remote AWS cloud nodes and return a structured summary.
    """
    compiled_incident_graph = build_incident_graph()
    result = compiled_incident_graph(incident_details)
    logger.info("Pipeline execution completed.")
    return result

