async def fetch_managed_prompt(prompt_id: str, prompt_version: str) -> dict:
    """
    Fetches the prompt from Bedrock Prompt Management.
    The response automatically includes any cachePoint configurations defined in the console.
    """
    logger.info(f"Fetching managed prompt {prompt_id}, version {prompt_version}")
    try:
        # Run synchronous boto3 call in an executor to avoid blocking the event loop
        response = await asyncio.to_thread(
            bedrock_agent_client.get_prompt,
            promptIdentifier=prompt_id,
            promptVersion=prompt_version
        )
        # Extract the default variant
        return response.get('variants', [{}])[0]
    except Exception as e:
        logger.error(f"Failed to fetch prompt from Bedrock Prompt Management: {e}")
        raise

async def invoke_with_prompt_caching(prompt_config: dict, user_input: str, fallback_model_id: str = "anthropic.claude-3-haiku-20240307-v1:0") -> str:
    """
    Invokes the Bedrock Runtime converse API using the fetched prompt configuration.
    Passes along the cache checkpoints to leverage Bedrock's Prompt Caching feature.
    """
    try:
        system_prompts = []
        
        # 1. Parse the template configuration to map system prompts and cache points
        if 'templateConfiguration' in prompt_config:
            if 'chat' in prompt_config['templateConfiguration']:
                system_blocks = prompt_config['templateConfiguration']['chat'].get('system', [])
                for block in system_blocks:
                    # Directly append blocks; the API accepts {"text": "..."} and {"cachePoint": {"type": "default"}}
                    system_prompts.append(block)
            elif 'text' in prompt_config['templateConfiguration']:
                # Fallback for simple text templates without specific cache points
                system_prompts.append({
                    "text": prompt_config['templateConfiguration']['text'].get('text', '')
                })

        # 2. Structure the dynamic user input
        messages = [{
            "role": "user",
            "content": [{"text": user_input}]
        }]

        # 3. Apply inference configurations defined in Prompt Management
        inference_config = prompt_config.get('inferenceConfiguration', {}).get('text', {})
        model_id = prompt_config.get('modelId', fallback_model_id)

        # 4. Execute Converse API with the cached definitions
        logger.info(f"Invoking model {model_id} with prompt caching enabled...")
        response = await asyncio.to_thread(
            bedrock_runtime_client.converse,
            modelId=model_id,
            system=system_prompts,
            messages=messages,
            inferenceConfig={
                "maxTokens": inference_config.get('maxTokens', 1024),
                "temperature": inference_config.get('temperature', 0.7),
                "topP": inference_config.get('topP', 0.9)
            }
        )
        
        # 5. Log token usage to verify cache hits
        usage = response.get('usage', {})
        logger.info(f"Token Usage -> Input (Total): {usage.get('inputTokens', 0)} | Output: {usage.get('outputTokens', 0)}")
        
        return response['output']['message']['content'][0]['text']

    except Exception as e:
        logger.error(f"Error during cached model invocation: {e}")
        raise

async def process_orchestrator_request(user_input: str):
    """
    Main orchestration function to fetch the managed prompt and execute it using cache optimization.
    """
    prompt_config = await fetch_managed_prompt(AWS_PROMPT_ID, AWS_PROMPT_VERSION)
    result = await invoke_with_prompt_caching(prompt_config, user_input)
    return result

