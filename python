# Load variables from local .env file
load_dotenv()
AWS_REGION = os.getenv("AWS_REGION", "us-east-1")

logging.basicConfig(level=logging.INFO)
logger = logging.getLogger(__name__)

# Initialize AWS Session early to allow SSM parameter loading
aws_session = boto3.Session(region_name=AWS_REGION)
ssm_client = aws_session.client('ssm')

def get_ssm_parameter(param_path: str, fallback_env: str) -> str:
    """Fetches a configuration value from AWS SSM Parameter Store with an env fallback."""
    try:
        response = ssm_client.get_parameter(Name=param_path, WithDecryption=False)
        return response['Parameter']['Value']
    except Exception as e:
        logger.debug(f"SSM path {param_path} not found or inaccessible ({e}). Falling back to environment variable.")
        return os.getenv(fallback_env, "")

AWS_PROMPT_ID = get_ssm_parameter("/config/analyzer_agent/prompt_id", "AWS_PROMPT_ID")
AWS_PROMPT_VERSION = get_ssm_parameter("/config/analyzer_agent/prompt_version", "AWS_PROMPT_VERSION")

bedrock_agent_client = aws_session.client('bedrock-agent')

#fetching system prompt
def get_bedrock_system_prompt(prompt_id: str, prompt_version: str, **variables) -> str:
    """
    Fetches the system prompt from AWS Bedrock using a retry mechanism.
    Injects dynamic variables into the prompt text.
    """
    if not prompt_id:
        logger.warning("AWS_PROMPT_ID is not set. Returning empty configuration.")
        return ""

    max_retries = 3
    for attempt in range(1, max_retries + 1):
        try:
            logger.info(f"Attempting to fetch configuration from Bedrock (ID: {prompt_id}, Version: {prompt_version}) - Try {attempt}")
            
            response = bedrock_agent_client.get_prompt(
                promptIdentifier=prompt_id,
                promptVersion=prompt_version
            )
            
            variants = response.get("variants", [])
            if not variants:
                logger.error(f"No variants found for prompt {prompt_id}.")
                return ""
                
            template_config = variants[0].get("templateConfiguration", {})
            prompt_text = template_config.get("text", {}).get("text", "")

            if not prompt_text:
                logger.error(f"Prompt text is empty in the response.")
                return ""

            # Inject dynamic variables
            for key, value in variables.items():
                prompt_text = prompt_text.replace(f"{{{{{key}}}}}", str(value))

            logger.info(f"Successfully fetched prompt from Bedrock prompt management '{prompt_text}")
            
            return prompt_text,

        except Exception as e:
            if attempt < max_retries:
                logger.warning(f"Attempt {attempt} failed due to error: {e}. Retrying in 2 seconds...")
                time.sleep(2)
            else:
                logger.error(f"Failed to fetch configuration from Bedrock after {max_retries} attempts due to error: {e}.")
                return ""

# Define dynamic variables based on environment and constants
dynamic_prompt_variables = {
    "knowledge_base_id": os.getenv("KNOWLEDGE_BASE_ID","")
}

# Fetch the combined configuration dictionary
SYSTEM_PROMPT = get_bedrock_system_prompt(
    prompt_id=AWS_PROMPT_ID,
    prompt_version=AWS_PROMPT_VERSION,
    **dynamic_prompt_variables
)

@tool
def knowledge_base_search(query: str) -> str:
    """Search the Bedrock knowledge base"""

    logger.info("Executing knowledge_base_search tool. Query: '%s'", query)

    kb_id = os.getenv("KNOWLEDGE_BASE_ID","")
    region = os.getenv("AWS_REGION", "us-east-1")

    if not kb_id:
        logger.error("KNOWLEDGE_BASE_ID is missing")
        return "Error: KNOWLEDGE_BASE_ID not configured"

    tool_input = {
        'toolUseId': 'kb-search',
        'input': {
            'text': query,
            'knowledgeBaseId': kb_id,
            'region': region,
            'numberOfResults': 5,
            'score': 0.35
        }
    }

    try:
        response = _kb_retrieve_fn(tool_input)

        status = response.get("status", "error")
        content = response.get("content", [])

        if status != "success" or not content:
            return f"No results found for: {query}"

        return content[0].get("text", f"No results found for: {query}")

    except Exception as e:
        logger.exception("Error in knowledge_base_search")
        return f"Search error: {str(e)}"


# ========================================================
#  RUNTIME AND ROUTING UTILITY
# ========================================================
def main():
    logger.info("Starting up AnalyzerAgent system bootstrap lifecycle...")
    
    is_local = os.getenv("ENV", "prod").lower() == "local"
    logger.info("Target execution mode evaluated: [ENV=%s] (is_local=%s)", os.getenv("ENV", "prod"), is_local)
    
    logger.info("Initializing Agent and tools within active OpenTelemetry context framework...")

    try:
        logger.info("Querying MCP Client tool discovery endpoint...")
        tools = build_tools_from_mcp()
        logger.info("MCP discovery complete. Discovered and parsed %d dynamic tools.", len(tools))
        
        logger.info("Loading language intelligence model configuration...")
        llm_model = load_model()
        logger.info("LLM engine loaded successfully: %s", getattr(llm_model, "model_id", "Default Model Instance"))

        logger.info("Assembling Strands Agent runtime configuration framework...")
        analyzer_agent = Agent(
            name="Analyzer Agent",    
            description="Provides insight on incident data.",  
            model=llm_model,
            system_prompt=SYSTEM_PROMPT,
            tools=[*tools, knowledge_base_search],
        )
        logger.info("Strands Agent assembly verified successfully.")

    except Exception as bootstrap_err:
        logger.critical("Fatal crash experienced during target component assembly pipeline initialization.", exc_info=True)
        raise bootstrap_err

    if is_local:
        logger.info("Configuring A2AServer routing interface loop on target port: 9002")
        a2a_server = A2AServer(
            agent=analyzer_agent, 
            port=9002
        )
        logger.info("Handing off runtime thread execution control to local HTTP polling loop...")
        a2a_server.serve()
    else:
        logger.info("Building production StrandsA2AExecutor. Running in AWS Bedrock AgentCore runtime environment...")
        executor = StrandsA2AExecutor(agent=analyzer_agent)
        
        logger.info("Running in AWS PRODUCTION environment via Bedrock AgentCore Runtime...")
        serve_a2a(executor)

if __name__ == "__main__":
    main()
