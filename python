def get_bedrock_system_prompt(prompt_id: str, prompt_version: str, **variables) -> str:
    """
    Fetches the system prompt from AWS Bedrock Prompt Management and injects dynamic variables.
    Requires Bedrock prompt variables to be formatted as {{variable_name}}.
    """
    if not prompt_id:
        logger.warning("AWS_PROMPT_ID is empty or not set. Falling back to the hardcoded default prompt.")
        return get_fallback_prompt()

    try:
        logger.info(f"Attempting to fetch Bedrock Prompt [ID: {prompt_id}, Version: {prompt_version or 'DRAFT'}]...")
        
        # Set up the API arguments
        kwargs = {'promptIdentifier': prompt_id}
        if prompt_version:
            kwargs['promptVersion'] = prompt_version

        # Fetch from Bedrock
        response = bedrock_agent_client.get_prompt(**kwargs)
        
        # Traverse the Bedrock response structure to extract the prompt text
        variants = response.get("variants", [])
        if not variants:
            logger.error(f"No variants found in the Bedrock prompt response for ID {prompt_id}. Using fallback prompt.")
            return get_fallback_prompt()
            
        template_config = variants[0].get("templateConfiguration", {})
        prompt_text = template_config.get("text", {}).get("text", "")

        if not prompt_text:
            logger.error(f"Prompt text is empty in the Bedrock response for ID {prompt_id}. Using fallback prompt.")
            return get_fallback_prompt()

        # Inject dynamic variables
        for key, value in variables.items():
            prompt_text = prompt_text.replace(f"{{{{{key}}}}}", str(value))
            
        logger.info(f"SUCCESS: Successfully fetched and configured Bedrock prompt '{prompt_id}'.")
        # Print a small preview of the prompt to confirm variable injection in the logs
        logger.info(f"Configured Prompt Preview: {prompt_text[:100]}...") 
        
        return prompt_text

    except bedrock_agent_client.exceptions.AccessDeniedException as e:
        logger.error(f"Access Denied fetching Bedrock Prompt. Verify IAM permissions and ensure you are using the 10-character Prompt ID (not the prompt name). Error: {e}")
        logger.info("Using the hardcoded fallback prompt due to AccessDeniedException.")
        return get_fallback_prompt()
    except Exception as e:
        logger.error(f"Unexpected error fetching prompt from Bedrock: {e}")
        logger.info("Using the hardcoded fallback prompt due to an unexpected error.")
        return get_fallback_prompt()


def get_fallback_prompt() -> str:
    """Provides a safe fallback if Bedrock fetch fails or ID is missing."""
    return """
    You are an expert incident orchestration agent responsible for coordinating a multi-stage analysis pipeline.
    Your responsibilities:
    1. Understand the full incident context.
    2. ALWAYS delegate processing to the execution pipeline tool.
    Strict rules:
    - DO NOT perform analysis yourself.
    - Return ONLY the pipeline result.
    """

# Define the dynamic variables you want to inject into the Bedrock prompt
dynamic_prompt_variables = {
    "environment": os.getenv("ENV", "prod").upper(),
    "target_audience": "L3 Support Engineers",
    "timeout_seconds": str(DEFAULT_TIMEOUT)
}

# Fetch the active system prompt dynamically at initialization
SYSTEM_PROMPT = get_bedrock_system_prompt(
    prompt_id=AWS_PROMPT_ID,
    prompt_version=AWS_PROMPT_VERSION,
    **dynamic_prompt_variables
)

orchestrator_agent = Agent(
    name="IncidentOrchestrator",
    description="Orchestrates the incident analysis pipeline and returns structured insights.",
    system_prompt=SYSTEM_PROMPT,
    tools=[execute_incident_analysis_pipeline]
)


def main():
    if is_local:
        logger.info("Running Master orchestrator in LOCAL mode via Strands A2AServer on port 9001...")
        a2a_server = A2AServer(
            agent=orchestrator_agent,
            port=9001
        )
        a2a_server.serve()
    else:
        logger.info("Running Master orchestrator in AWS PRODUCTION environment via Bedrock AgentCore Runtime...")
        executor = StrandsA2AExecutor(agent=orchestrator_agent)
        serve_a2a(executor)

if __name__ == "__main__":
    main()
