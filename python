def _make_sigv4_async_client(timeout: int = DEFAULT_TIMEOUT) -> httpx.AsyncClient:
    """Return a configured AsyncClient signed with SigV4 for Bedrock AgentCore."""
    creds = aws_session.get_credentials()
    sigv4_auth = SigV4HTTPXAuth(creds, "bedrock-agentcore", aws_session.region_name)
    return httpx.AsyncClient(timeout=timeout, auth=sigv4_auth)


# Graph node / agent name constants
ANALYSIS_NODE = "analysis_step"
SUMMARY_NODE = "summary_step"
ANALYZER_AGENT_NAME = "analyzer_agent"
SUMMARIZER_AGENT_NAME = "summarizer_agent"


def build_incident_graph():
    """Create a fresh graph per invocation to avoid cross-event-loop client reuse."""
    graph = GraphBuilder()

    if USE_LOCAL_AGENTS:
        analyzer_remote_agent = A2AAgent(endpoint="http://localhost:9002", name=ANALYZER_AGENT_NAME)
        summarizer_remote_agent = A2AAgent(endpoint="http://localhost:9003", name=SUMMARIZER_AGENT_NAME)
    else:
        analyzer_ep = ENDPOINTS.get("analyzer")
        summarizer_ep = ENDPOINTS.get("summarizer")
        if not analyzer_ep or not summarizer_ep:
            raise RuntimeError(
                "Agent endpoints are not initialized. Ensure registry resolution completed at startup."
            )

        analyzer_httpx_client = _make_sigv4_async_client()
        summarizer_httpx_client = _make_sigv4_async_client()

        analyzer_remote_agent = A2AAgent(
            endpoint=analyzer_ep,
            name=ANALYZER_AGENT_NAME,
            client_config=ClientConfig(httpx_client=analyzer_httpx_client),
        )
        summarizer_remote_agent = A2AAgent(
            endpoint=summarizer_ep,
            name=SUMMARIZER_AGENT_NAME,
            client_config=ClientConfig(httpx_client=summarizer_httpx_client),
        )

    graph.add_node(analyzer_remote_agent, ANALYSIS_NODE)
    graph.add_node(summarizer_remote_agent, SUMMARY_NODE)
    graph.add_edge(ANALYSIS_NODE, SUMMARY_NODE)
    graph.set_entry_point(ANALYSIS_NODE)
    return graph.build()


