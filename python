bedrock_agent_client = aws_session.client('bedrock-agent')

def get_bedrock_configuration(prompt_id: str, prompt_version: str, **variables) -> dict:
    """
    Fetches the system prompt and inference configurations from AWS Bedrock using a retry mechanism.
    Injects dynamic variables into the prompt text.
    """
    if not prompt_id:
        logger.warning("AWS_PROMPT_ID is not set. Returning empty configuration.")
        return {"prompt_text": "", "model_settings": {}}

    max_retries = 3
    for attempt in range(1, max_retries + 1):
        try:
            logger.info(f"Attempting to fetch configuration from Bedrock (ID: {prompt_id}, Version: {prompt_version}) - Try {attempt}")
            
            response = bedrock_agent_client.get_prompt(
                promptIdentifier=prompt_id,
                promptVersion=prompt_version
            )
            logger.info(response)
            variants = response.get("variants", [])
            if not variants:
                logger.error(f"No variants found for prompt {prompt_id}.")
                return {"prompt_text": "", "model_settings": {}}
                
            template_config = variants[0].get("templateConfiguration", {})
            prompt_text = template_config.get("text", {}).get("text", "")

            if not prompt_text:
                logger.error(f"Prompt text is empty in the response.")
                return {"prompt_text": "", "model_settings": {}}

            # Extract the Model Configurations from AWS Console
            inference_config = variants[0].get("inferenceConfiguration", {}).get("text", {})
            
            model_settings = {
                "temperature": inference_config.get("temperature", 0.0),
                "top_p": inference_config.get("topP", 1.0),
                "max_tokens": inference_config.get("maxTokens", 2000),
                "stop_sequences": inference_config.get("stopSequences", [])
            }

            # Inject dynamic variables
            for key, value in variables.items():
                prompt_text = prompt_text.replace(f"{{{{{key}}}}}", str(value))

            logger.info(f"Successfully fetched prompt from Bedrock prompt management '{prompt_text}")   
            logger.info(f"Successfully fetched prompt from Bedrock prompt management '{model_settings}")
            
            return {
                "prompt_text": prompt_text,
                "model_settings": model_settings
            }

        except Exception as e:
            if attempt < max_retries:
                logger.warning(f"Attempt {attempt} failed due to error: {e}. Retrying in 2 seconds...")
                time.sleep(2)
            else:
                logger.error(f"Failed to fetch configuration from Bedrock after {max_retries} attempts due to error: {e}.")
                return {"prompt_text": "", "model_settings": {}}


