def get_bedrock_system_prompt(prompt_id: str, prompt_version: str, **variables) -> str:
    """
    Fetches the system prompt from AWS Bedrock Prompt Management and injects dynamic variables.
    Requires Bedrock prompt variables to be formatted as {{variable_name}}.
    """
    if not prompt_id:
        logger.warning("AWS_PROMPT_ID is not set in environment. Going for fallback prompt.")
        return get_fallback_prompt()

    try:
        logger.info(f"Attempting to fetch prompt from Bedrock (ID: {prompt_id}, Version: {prompt_version})")
        
        response = bedrock_agent_client.get_prompt(
            promptIdentifier=prompt_id,
            promptVersion=prompt_version
        )
        
        variants = response.get("variants", [])
        if not variants:
            logger.error(f"No variants found for prompt {prompt_id}. Going for fallback prompt.")
            return get_fallback_prompt()
            
        template_config = variants[0].get("templateConfiguration", {})
        prompt_text = template_config.get("text", {}).get("text", "")

        if not prompt_text:
            logger.error(f"Prompt text is empty in the response. Going for fallback prompt.")
            return get_fallback_prompt()

        # Inject dynamic variables
        for key, value in variables.items():
            prompt_text = prompt_text.replace(f"{{{{{key}}}}}", str(value))
            
        logger.info(f"Successfully fetched and injected variables for Bedrock prompt '{prompt_id}'")
        return prompt_text

    except Exception as e:
        logger.error(f"Failed to fetch prompt from Bedrock due to error: {e}. Going for fallback prompt.")
        return get_fallback_prompt()


