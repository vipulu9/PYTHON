import boto3
import json
from strands.models.bedrock import BedrockModel

class CacheInterceptingClient:
    """
    A wrapper class that intercepts the Boto3 Bedrock Runtime client.
    It injects prompt caching markers and explicitly logs usage details.
    """
    def __init__(self):
        self._real_client = boto3.client("bedrock-runtime")
        
    def converse(self, **kwargs):
        print("\n⚡ [INTERCEPTOR] converse() method triggered by Strands framework!")
        
        # 1. Inject Cache Point into the System Instructions
        if "system" in kwargs and isinstance(kwargs["system"], list):
            if kwargs["system"]:
                kwargs["system"].append({"cachePoint": {"type": "default"}})
                print("📌 [INTERCEPTOR] Injected cachePoint into System Prompts")
                
        # 2. Inject Cache Point into the Tools 
        if "toolConfig" in kwargs and "tools" in kwargs["toolConfig"]:
            if kwargs["toolConfig"]["tools"]:
                kwargs["toolConfig"]["tools"].append({"cachePoint": {"type": "default"}})
                print("📌 [INTERCEPTOR] Injected cachePoint into Tools")
                
        # 3. Execute the actual API call
        response = self._real_client.converse(**kwargs)
        
        # 4. Explicit Metrics Logging
        try:
            usage = response.get('usage', {})
            print("\n" + "="*45)
            print("💰 BEDROCK TOKEN USAGE REPORT (converse)")
            print("="*45)
            print(f"Total Input Tokens:    {usage.get('inputTokens', 'N/A')}")
            print(f"Total Output Tokens:   {usage.get('outputTokens', 'N/A')}")
            print(f"Tokens Cached (Write): {usage.get('cacheCreationInputTokenCount', 0)}")
            print(f"Tokens Read (Cache):   {usage.get('cacheReadInputTokenCount', 0)}")
            print("="*45 + "\n")
        except Exception as e:
            print(f"❌ [INTERCEPTOR ERROR] Failed to parse converse metrics: {e}")
            
        return response

    def invoke_model(self, **kwargs):
        """Fallback interceptor in case Strands uses the older invoke_model API."""
        print("\n⚡ [INTERCEPTOR] invoke_model() method triggered by Strands framework!")
        
        # If strands uses invoke_model, kwargs['body'] contains a string/bytes JSON payload
        if "body" in kwargs:
            try:
                body_data = json.loads(kwargs["body"])
                # Perform injection depending on Bedrock's anthropic native structure if applicable
                # (This is a fallback safeguard)
                kwargs["body"] = json.dumps(body_data)
            except Exception as e:
                print(f"⚠️ [INTERCEPTOR] Could not modify invoke_model body: {e}")

        response = self._real_client.invoke_model(**kwargs)
        
        try:
            print("\n" + "="*45)
            print("💰 BEDROCK RESPONSE RECEIVED (invoke_model)")
            print("="*45)
            # Standard invoke_model doesn't return cache tokens in the same way, 
            # but this verifies the call is going through here.
            print("Call successful. Check response headers or body for usage tokens.")
            print("="*45 + "\n")
        except Exception as e:
            print(f"❌ [INTERCEPTOR ERROR] Failed during invoke_model logging: {e}")
            
        return response
        
    def __getattr__(self, name):
        # Fallback for any other methods called by the framework
        return getattr(self._real_client, name)


def load_model() -> BedrockModel:
    """Get Bedrock model client and inject the caching interceptor."""
    caching_client = CacheInterceptingClient()
    
    model = BedrockModel(model_id="global.anthropic.claude-sonnet-4-5-20250929-v1:0")
    
    # Forcefully override the library's internal client references
    if hasattr(model, 'client'):
        model.client = caching_client
    if hasattr(model, '_client'):
        model._client = caching_client
    if hasattr(model, 'bedrock_client'):
        model.bedrock_client = caching_client
        
    return model
