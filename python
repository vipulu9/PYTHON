from mcp.server.fastmcp import FastMCP
import os
import requests
import urllib3
from dotenv import load_dotenv
from typing import Any, Optional

# --- OTel Tracing Imports ---
from opentelemetry import trace
from opentelemetry.propagate import extract
from opentelemetry.context import attach, detach
from contextlib import contextmanager

load_dotenv()
urllib3.disable_warnings()

mcp = FastMCP("ServiceNow CRUD Server", host="0.0.0.0", stateless_http=True)
tracer = trace.get_tracer(__name__)

INSTANCE = os.getenv("SERVICENOW_INSTANCE")
USERNAME = os.getenv("SERVICENOW_USERNAME")
PASSWORD = os.getenv("SERVICENOW_PASSWORD")
BASE_URL = f"https://{INSTANCE}/api/now/table/incident"

_BASE_HEADERS = {
    "Content-Type": "application/json",
    "Accept": "application/json",
}

@contextmanager
def trace_propagation(kwargs: dict, span_name: str):
    """Extracts injected trace context and links it to the active trace."""
    trace_ctx = kwargs.get("_trace_context")
    token = None
    if trace_ctx:
        ctx = extract(trace_ctx)
        token = attach(ctx)
    try:
        with tracer.start_as_current_span(span_name):
            yield
    finally:
        if token is not None:
            detach(token)

def _get_session() -> tuple[str, requests.Session]:
    if not INSTANCE:
        raise RuntimeError("SNOW_INSTANCE environment variable is not set.")
    base_url = f"https://{INSTANCE}/api/now"
    session = requests.Session()
    session.headers.update(_BASE_HEADERS)

    client_id = os.environ.get("SNOW_CLIENT_ID")
    client_secret = os.environ.get("SNOW_CLIENT_SECRET")

    if client_id and client_secret:
        token_url = f"https://{INSTANCE}/oauth_token.do"
        resp = requests.post(
            token_url,
            data={
                "grant_type": "client_credentials",
                "client_id": client_id,
                "client_secret": client_secret,
            },
            timeout=15,
        )
        resp.raise_for_status()
        token = resp.json()["access_token"]
        session.headers["Authorization"] = f"Bearer {token}"
    else:
        username = USERNAME
        password = PASSWORD
        if not username or not password:
            raise RuntimeError("Set credentials for basic auth or OAuth.")
        session.auth = (username, password)
    return base_url, session

def _table_url(base_url: str, table: str, sys_id: str = "") -> str:
    path = f"{base_url}/table/{table}"
    return f"{path}/{sys_id}" if sys_id else path

def _check(resp: requests.Response) -> dict[str, Any]:
    resp.raise_for_status()
    return resp.json()

def get_auth():
    return (USERNAME, PASSWORD)

# =====================================================
# CREATE
# =====================================================

@mcp.tool()
def create_incident(short_description: str, description: Optional[str] = None, **kwargs):
    with trace_propagation(kwargs, "create_incident"):
        payload = {"short_description": short_description}
        if description:
            payload["description"] = description
        response = requests.post(BASE_URL, auth=get_auth(), json=payload, verify=False)
        response.raise_for_status()
        return response.json()

# =====================================================
# READ
# =====================================================

@mcp.tool()
def get_incident(incident_number: str, **kwargs):
    with trace_propagation(kwargs, "get_incident"):
        params = {
            "sysparm_query": f"number={incident_number}",
            "sysparm_limit": 1,
            "sysparm_display_value": "true",
        }
        response = requests.get(BASE_URL, auth=get_auth(), params=params, verify=False)
        response.raise_for_status()
        data = response.json()
        if not data["result"]:
            return {"success": False, "message": "Incident not found"}
        return data["result"][0]

# =====================================================
# UPDATE
# =====================================================

@mcp.tool()
def update_incident(
    incident_number: str, state: Optional[int] = None, work_notes: Optional[str] = None, **kwargs
):
    with trace_propagation(kwargs, "update_incident"):
        incident = get_incident(incident_number)
        if not incident.get("sys_id"):
            return {"success": False, "message": "Incident not found"}
        
        payload = {}
        if state:
            payload["state"] = state
        if work_notes:
            payload["work_notes"] = work_notes

        response = requests.patch(
            f"{BASE_URL}/{incident['sys_id']}", auth=get_auth(), json=payload, verify=False
        )
        response.raise_for_status()
        return response.json()

# =====================================================
# DELETE
# =====================================================

@mcp.tool()
def delete_incident(incident_number: str, **kwargs):
    with trace_propagation(kwargs, "delete_incident"):
        incident = get_incident(incident_number)
        if not incident.get("sys_id"):
            return {"success": False, "message": "Incident not found"}
            
        response = requests.delete(
            f"{BASE_URL}/{incident['sys_id']}", auth=get_auth(), verify=False
        )
        response.raise_for_status()
        return {"success": True, "message": f"{incident_number} deleted"}

# =====================================================
# SEARCH
# =====================================================

@mcp.tool()
def search_incidents(
    query: str,
    state: Optional[str] = None,
    priority: Optional[str] = None,
    assigned_to: Optional[str] = None,
    limit: int = 10,
    **kwargs
) -> list[dict[str, Any]]:
    with trace_propagation(kwargs, "search_incidents"):
        base_url, session = _get_session()
        parts = [query] if query else []
        if state:
            parts.append(f"state={state}")
        if priority:
            parts.append(f"priority={priority}")
        if assigned_to:
            parts.append(f"assigned_to.user_name={assigned_to}")

        encoded = "^".join(parts) if parts else "active=true"
        resp = session.get(
            _table_url(base_url, "incident"),
            params={
                "sysparm_query": encoded,
                "sysparm_limit": min(limit, 100),
                "sysparm_fields": (
                "number,short_description,description,"
                "work_notes,comments,close_notes,"
                "state,priority,assigned_to,"
                "opened_at,resolved_at,caller_id,category,sys_id"
            ),
            },
            timeout=15,
        )
        return _check(resp).get("result", [])

# =====================================================
# RESOURCE
# =====================================================

@mcp.resource("servicenow://status")
def status():
    return "ServiceNow CRUD MCP Running"

PORT = int(os.getenv("PORT", "8000"))

if __name__ == "__main__":
    mcp.run(transport="streamable-http")
